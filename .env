PORT = 3000
NODE_ENV=development

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=urlshortener

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
BASE_URL=http://localhost:3000
CACHE_TTL=3600          # seconds — how long short→long URL lives in Redis
RATE_LIMIT_WINDOW=60000 # ms
RATE_LIMIT_MAX=10 